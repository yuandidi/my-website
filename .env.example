DATABASE_URL=postgresql://blog:blog@localhost:5432/blog
POSTGRES_URL=postgresql://blog:blog@localhost:5432/blog
API_PORT=3000
# Next.js 同域 API，前端固定请求 /api（无需 NEXT_PUBLIC_API_URL）

# GitHub OAuth（所有人可登录；下方账号为开发者权限）
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_DEVELOPER_LOGIN=yuandidi

# 会话签名密钥（随机长字符串）
AUTH_SESSION_SECRET=

# 站点根 URL（OAuth 回调、RSS、sitemap、Open Graph 绝对链接）
SITE_URL=http://localhost:3000

# Giscus 评论（仓库 yuandidi/my-blog-comments）
NEXT_PUBLIC_GISCUS_REPO=yuandidi/my-blog-comments
NEXT_PUBLIC_GISCUS_REPO_ID=R_kgDOTA9QKA
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDOTA9QKM4C_mgJ
# 可选：自定义 Giscus 主题 CSS 绝对/根路径 URL；留空则使用站点 /giscus-theme-{light,dark}.css 并随系统深浅色切换
# NEXT_PUBLIC_GISCUS_THEME=