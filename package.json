{
  "name": "my-blog",
  "private": true,
  "scripts": {
    "dev": "pnpm dlx vercel@latest dev",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm --filter @my-blog/shared build && pnpm --filter web build",
    "typecheck": "tsc --noEmit",
    "check": "pnpm build && pnpm typecheck && pnpm --filter web lint",
    "deploy:vercel": "pnpm dlx vercel@latest --prod",
    "db:push": "dotenv -e .env -- tsx scripts/db-push.ts",
    "db:seed": "dotenv -e .env -- tsx scripts/seed.ts",
    "db:setup": "pnpm db:push && pnpm db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@my-blog/shared": "workspace:*",
    "@neondatabase/serverless": "^1.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@vercel/node": "^5.3.0",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
